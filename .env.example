# ──────────────────────────────────────────────
# Base de datos principal (PostgreSQL en Supabase)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.
DATABASE_TYPE=postgresql
DATABASE_ECHO=False

# ──────────────────────────────────────────────
# JWT (Autenticación)
# ──────────────────────────────────────────────
SECRET_KEY_JWT=[LLAVE_SECRETA]
ALGORITHIM_HASH_JWT=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=90